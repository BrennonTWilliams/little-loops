{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{LL_PLUGIN_ROOT}}/hooks/adapters/codex/session-start.sh",
            "timeout": 30,
            "statusMessage": "Loading ll config..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{LL_PLUGIN_ROOT}}/hooks/adapters/codex/pre-compact.sh",
            "timeout": 60,
            "statusMessage": "Preserving task state..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{LL_PLUGIN_ROOT}}/hooks/adapters/codex/prompt-submit.sh",
            "timeout": 5,
            "statusMessage": "Checking prompt..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{LL_PLUGIN_ROOT}}/hooks/adapters/codex/post-tool-use.sh",
            "timeout": 5,
            "statusMessage": "Recording tool use..."
          }
        ]
      }
    ]
  }
}
