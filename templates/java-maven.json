{
  "$schema": "../config-schema.json",
  "_meta": {
    "name": "Java (Maven)",
    "description": "Java project with Maven build system",
    "detect": [
      "pom.xml"
    ],
    "tags": [
      "java",
      "maven",
      "jvm"
    ],
    "command_options": {
      "test_cmd": ["mvn test", "mvn test -pl .", "mvn verify"],
      "lint_cmd": ["mvn checkstyle:check", "mvn pmd:check", "mvn spotbugs:check"]
    }
  },
  "project": {
    "src_dir": "src/main/java/",
    "test_cmd": "mvn test",
    "lint_cmd": "mvn checkstyle:check",
    "type_cmd": null,
    "format_cmd": null,
    "build_cmd": "mvn package -DskipTests",
    "run_cmd": "mvn exec:java"
  },
  "scan": {
    "focus_dirs": [
      "src/main/java/",
      "src/test/java/"
    ],
    "exclude_patterns": [
      "**/target/**",
      "**/.idea/**",
      "**/*.class"
    ]
  },
  "issues": {
    "base_dir": ".issues",
    "categories": {
      "bugs": {
        "prefix": "BUG",
        "dir": "bugs",
        "action": "fix"
      },
      "features": {
        "prefix": "FEAT",
        "dir": "features",
        "action": "implement"
      },
      "enhancements": {
        "prefix": "ENH",
        "dir": "enhancements",
        "action": "improve"
      },
      "epics": {
        "prefix": "EPIC",
        "dir": "epics",
        "action": "coordinate"
      }
    }
  },
  "product": {
    "enabled": false
  },
  "analytics": {
    "enabled": false
  },
  "context_monitor": {
    "enabled": true
  }
}
