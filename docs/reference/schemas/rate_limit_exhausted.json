{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-rate_limit_exhausted.json",
  "title": "Rate Limit Exhausted",
  "description": "Emitted when all 429/rate-limit retries for a state are exhausted.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "state",
    "retries"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "state": {
      "type": "string",
      "description": "State name that exhausted rate-limit retries"
    },
    "retries": {
      "type": "integer",
      "description": "Number of rate-limit retries attempted"
    },
    "next": {
      "type": [
        "string",
        "null"
      ],
      "description": "Next state the FSM transitions to, or null if none"
    }
  },
  "additionalProperties": true
}
