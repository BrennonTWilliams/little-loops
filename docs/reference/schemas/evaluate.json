{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-evaluate.json",
  "title": "Evaluate",
  "description": "Emitted when an evaluator runs against action output.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "type",
    "verdict"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "type": {
      "type": "string",
      "description": "Evaluator type identifier"
    },
    "verdict": {
      "type": "string",
      "description": "Evaluator verdict (e.g. pass, fail, retry)"
    }
  },
  "additionalProperties": true
}
