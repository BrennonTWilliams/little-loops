{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-parallel.worker_completed.json",
  "title": "Parallel: Worker Completed",
  "description": "Emitted by the parallel orchestrator when a worker finishes processing an issue.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "issue_id",
    "worker_name",
    "status",
    "duration_seconds"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "issue_id": {
      "type": "string",
      "description": "Issue identifier processed by the worker"
    },
    "worker_name": {
      "type": "string",
      "description": "Worker name or identifier"
    },
    "status": {
      "type": "string",
      "description": "Completion status (e.g. completed, failed, deferred)"
    },
    "duration_seconds": {
      "type": "number",
      "description": "Wall-clock time in seconds"
    }
  },
  "additionalProperties": true
}
