{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-issue.failure_captured.json",
  "title": "Issue: Failure Captured",
  "description": "Emitted when an issue failure is captured and persisted as a bug report.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "issue_id",
    "file_path",
    "parent_issue_id"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "issue_id": {
      "type": "string",
      "description": "Issue identifier"
    },
    "file_path": {
      "type": "string",
      "description": "Path to the issue file"
    },
    "parent_issue_id": {
      "type": "string",
      "description": "Identifier of the parent issue that failed"
    }
  },
  "additionalProperties": true
}
