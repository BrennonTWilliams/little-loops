{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-route.json",
  "title": "Route",
  "description": "Emitted when the FSM transitions between states.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "from",
    "to"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "from": {
      "type": "string",
      "description": "Source state name"
    },
    "to": {
      "type": "string",
      "description": "Destination state name"
    },
    "reason": {
      "type": "string",
      "description": "Optional transition reason"
    }
  },
  "additionalProperties": true
}
