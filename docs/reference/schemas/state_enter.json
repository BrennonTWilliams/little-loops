{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-state_enter.json",
  "title": "State Enter",
  "description": "Emitted when the FSM enters a state.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "state",
    "iteration"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "state": {
      "type": "string",
      "description": "State name"
    },
    "iteration": {
      "type": "integer",
      "description": "Iteration count (1-based)"
    }
  },
  "additionalProperties": true
}
