{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-handoff_spawned.json",
  "title": "Handoff Spawned",
  "description": "Emitted when a new process is spawned to continue after a handoff.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "pid",
    "state"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "pid": {
      "type": "integer",
      "description": "Process ID of the spawned continuation process"
    },
    "state": {
      "type": "string",
      "description": "State name the continuation will resume from"
    }
  },
  "additionalProperties": true
}
