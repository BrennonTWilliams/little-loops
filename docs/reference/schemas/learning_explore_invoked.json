{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-learning_explore_invoked.json",
  "title": "Learning Explore Invoked",
  "description": "Emitted just before the learning state invokes /ll:explore-api for a target. Pairs with action_start/action_complete from the underlying skill invocation.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "state",
    "target",
    "attempt"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "state": {
      "type": "string",
      "description": "State name executing the learning dispatch"
    },
    "target": {
      "type": "string",
      "description": "Target identifier being explored"
    },
    "attempt": {
      "type": "integer",
      "description": "Attempt number, 1-based, capped by learning.max_retries"
    }
  },
  "additionalProperties": true
}
