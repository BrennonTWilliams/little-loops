{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-learning_target_refuted.json",
  "title": "Learning Target Refuted",
  "description": "Emitted when a target's registry record has status='refuted'. Routes to on_blocked / on_no.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "state",
    "target"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "state": {
      "type": "string",
      "description": "State name executing the learning dispatch"
    },
    "target": {
      "type": "string",
      "description": "Target identifier"
    }
  },
  "additionalProperties": true
}
