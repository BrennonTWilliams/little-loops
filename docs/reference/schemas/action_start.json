{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-action_start.json",
  "title": "Action Start",
  "description": "Emitted when a state action begins.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "action",
    "is_prompt"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "action": {
      "type": "string",
      "description": "Action name or command"
    },
    "is_prompt": {
      "type": "boolean",
      "description": "True if action is a Claude prompt, false for shell command"
    }
  },
  "additionalProperties": true
}
