{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "little-loops://event-issue.completed.json",
  "title": "Issue: Completed",
  "description": "Emitted when an issue is successfully completed.",
  "type": "object",
  "required": [
    "event",
    "ts",
    "issue_id",
    "file_path"
  ],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type identifier"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "issue_id": {
      "type": "string",
      "description": "Issue identifier"
    },
    "file_path": {
      "type": "string",
      "description": "Path to the completed issue file"
    }
  },
  "additionalProperties": true
}
