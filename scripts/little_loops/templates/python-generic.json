{
  "$schema": "../config-schema.json",
  "_meta": {
    "name": "Python (Generic)",
    "description": "Standard Python project with pytest, ruff, and mypy",
    "detect": [
      "pyproject.toml",
      "setup.py",
      "requirements.txt"
    ],
    "tags": [
      "python",
      "pytest",
      "ruff",
      "mypy"
    ],
    "command_options": {
      "test_cmd": ["pytest", "pytest -v", "python -m pytest"],
      "lint_cmd": ["ruff check .", "flake8", "pylint"],
      "format_cmd": ["ruff format .", "black .", "autopep8"]
    }
  },
  "project": {
    "src_dir": "src/",
    "test_cmd": "pytest",
    "lint_cmd": "ruff check .",
    "type_cmd": "mypy",
    "format_cmd": "ruff format .",
    "build_cmd": null,
    "run_cmd": null
  },
  "scan": {
    "focus_dirs": [
      "src/",
      "tests/"
    ],
    "exclude_patterns": [
      "**/__pycache__/**",
      "**/.venv/**",
      "**/venv/**",
      "**/dist/**",
      "**/build/**",
      "**/*.egg-info/**"
    ]
  },
  "issues": {
    "base_dir": ".issues",
    "categories": {
      "bugs": {
        "prefix": "BUG",
        "dir": "bugs",
        "action": "fix"
      },
      "features": {
        "prefix": "FEAT",
        "dir": "features",
        "action": "implement"
      },
      "enhancements": {
        "prefix": "ENH",
        "dir": "enhancements",
        "action": "improve"
      },
      "epics": {
        "prefix": "EPIC",
        "dir": "epics",
        "action": "coordinate"
      }
    }
  },
  "parallel": {
    "use_feature_branches": false,
    "epic_branches": { "enabled": false }
  },
  "product": {
    "enabled": false
  },
  "analytics": {
    "enabled": false
  },
  "context_monitor": {
    "enabled": true
  }
}
