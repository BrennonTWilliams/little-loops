{
  "$schema": "config-schema.json",
  "_meta": {
    "name": ".NET",
    "description": ".NET/C# project with dotnet CLI",
    "detect": [
      "*.csproj",
      "*.sln",
      "*.fsproj"
    ],
    "tags": [
      "dotnet",
      "csharp",
      "fsharp"
    ],
    "command_options": {
      "test_cmd": ["dotnet test", "dotnet test --logger trx", "dotnet test --no-build"],
      "lint_cmd": ["dotnet format --verify-no-changes", "dotnet build /p:TreatWarningsAsErrors=true"],
      "format_cmd": ["dotnet format", "dotnet format --include src/"]
    }
  },
  "project": {
    "src_dir": "src/",
    "test_cmd": "dotnet test",
    "lint_cmd": "dotnet format --verify-no-changes",
    "type_cmd": null,
    "format_cmd": "dotnet format",
    "build_cmd": "dotnet build",
    "run_cmd": "dotnet run"
  },
  "scan": {
    "focus_dirs": [
      "src/",
      "tests/"
    ],
    "exclude_patterns": [
      "**/bin/**",
      "**/obj/**",
      "**/.vs/**"
    ]
  },
  "issues": {
    "base_dir": ".issues",
    "categories": {
      "bugs": {
        "prefix": "BUG",
        "dir": "bugs",
        "action": "fix"
      },
      "features": {
        "prefix": "FEAT",
        "dir": "features",
        "action": "implement"
      },
      "enhancements": {
        "prefix": "ENH",
        "dir": "enhancements",
        "action": "improve"
      },
      "epics": {
        "prefix": "EPIC",
        "dir": "epics",
        "action": "coordinate"
      }
    }
  },
  "parallel": {
    "use_feature_branches": false,
    "epic_branches": { "enabled": false }
  },
  "product": {
    "enabled": false
  },
  "analytics": {
    "enabled": false
  },
  "context_monitor": {
    "enabled": true
  }
}
