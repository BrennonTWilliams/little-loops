name: {{target_name}}-task
category: generated
input_key: goal
description: |
  Generated task loop for {{target_name}} (desktop-gui classification).
  Emitted by cli-anything-bootstrap. Drives the cached CLI at {{cli_path}}
  toward a user goal, verifying via the CLI's own render/export commands
  (screenshot-based oracle for visual targets).

  Substitution variables filled at emission:
    {{target_name}} — short kebab-case name of the target software
    {{cli_path}}    — absolute path to the bootstrapped CLI binary
initial: init
max_steps: 8
timeout: 1800

context:
  goal: ""
  cli_path: "{{cli_path}}"
  pass_threshold: 7

states:

  init:
    action_type: shell
    action: |
      DIR="${context.run_dir}"
      mkdir -p "$DIR"
      echo "$(pwd)/$DIR"
    capture: run_dir
    next: plan

  plan:
    action_type: prompt
    action: |
      Goal: ${context.goal}
      CLI: ${context.cli_path}

      Inspect ${context.cli_path} --help and relevant subcommand helps. Write a bash
      script to ${captured.run_dir.output}/plan.sh that:
      - Runs {{target_name}} CLI commands to achieve the goal
      - Writes the final visual output to ${captured.run_dir.output}/output.<ext>
        (use the natural format: .png for renders, .blend/.xcf for project files,
         export to .png alongside for the screenshot oracle)
      - Is idempotent — safe to re-run

      If ${captured.run_dir.output}/critique.md exists, address its "Issues to Address"
      section before introducing new ideas.
    next: execute

  execute:
    action_type: shell
    action: |
      RUN_DIR="${captured.run_dir.output}"
      bash "$RUN_DIR/plan.sh" > "$RUN_DIR/execute.log" 2>&1
      EXEC_RC=$?
      printf "exec_rc=%d\n" "$EXEC_RC"
      tail -15 "$RUN_DIR/execute.log"
      exit $EXEC_RC
    evaluate:
      type: exit_code
    on_yes: screenshot
    on_no: score

  screenshot:
    action_type: shell
    action: |
      RUN_DIR="${captured.run_dir.output}"
      OUTPUT=$(find "$RUN_DIR" -type f \( -name "output.*" -o -name "render.*" \) -newer "$RUN_DIR/plan.sh" 2>/dev/null | grep -E '\.(png|jpg|jpeg|webp)$' | head -1)
      if [ -z "$OUTPUT" ]; then
        echo "NO_SCREENSHOT_OUTPUT" > "$RUN_DIR/screenshot.txt"
        exit 1
      fi
      cp "$OUTPUT" "$RUN_DIR/screenshot.png"
      echo "captured: $OUTPUT"
    evaluate:
      type: exit_code
    on_yes: score
    on_no: score

  score:
    action_type: prompt
    action: |
      Goal: ${context.goal}
      Read ${captured.run_dir.output}/screenshot.png if it exists.
      Otherwise read ${captured.run_dir.output}/execute.log to diagnose the failure.

      Score the result 1-10 against the goal. Write ${captured.run_dir.output}/critique.md:

      ```
      # Score
      goal: ${context.goal}
      result_score: N/10
      reasoning: <one paragraph — what worked, what missed>

      ## Issues to Address
      [Specific, actionable critique for the planner. Empty if goal met.]
      ```

      If result_score >= ${context.pass_threshold}, output exactly: GOAL_MET
      Otherwise output: ITERATE
    evaluate:
      type: output_contains
      pattern: "GOAL_MET"
    on_yes: done
    on_no: plan
    on_error: done

  done:
    action_type: prompt
    action: |
      {{target_name}}-task completed.
      Output: ${captured.run_dir.output}/
      Final render: screenshot.png (if produced)
      Plan: plan.sh
      Critique history: critique.md
    terminal: true
