name: {{target_name}}-task
category: generated
input_key: goal
description: |
  Generated task loop for {{target_name}} (data-lib classification).
  Emitted by cli-anything-bootstrap. Drives the cached CLI at {{cli_path}}
  toward a user goal. Primary success gate is exit_code on a planner-written
  assert script — the LLM score state only runs on failure to produce
  refinement critique.

  Substitution variables filled at emission:
    {{target_name}} — short kebab-case name of the target software
    {{cli_path}}    — absolute path to the bootstrapped CLI binary
initial: init
max_steps: 5
timeout: 900

context:
  goal: ""
  cli_path: "{{cli_path}}"

states:

  init:
    action_type: shell
    action: |
      DIR="${context.run_dir}"
      mkdir -p "$DIR"
      case "$DIR" in
        /*) echo "$DIR" ;;
        *) echo "$(pwd)/$DIR" ;;
      esac
    capture: run_dir
    next: plan

  plan:
    action_type: prompt
    action: |
      Goal: ${context.goal}
      CLI: ${context.cli_path}

      Write two scripts:
      - ${captured.run_dir.output}/plan.sh    — runs {{target_name}} CLI to achieve goal
      - ${captured.run_dir.output}/assert.sh  — exits 0 iff the goal is provably achieved
                                                (assert on output files, --json structure,
                                                 or CLI read-command results)

      If ${captured.run_dir.output}/critique.md exists, fix the issues it lists.

      The assert script is the success gate — make its checks specific and verifiable.
    next: execute

  execute:
    action_type: shell
    action: |
      RUN_DIR="${captured.run_dir.output}"
      bash "$RUN_DIR/plan.sh" > "$RUN_DIR/execute.log" 2>&1
      EXEC_RC=$?
      printf "exec_rc=%d\n" "$EXEC_RC"
      tail -10 "$RUN_DIR/execute.log"
      exit $EXEC_RC
    evaluate:
      type: exit_code
    on_yes: assert
    on_no: score

  assert:
    action_type: shell
    action: |
      RUN_DIR="${captured.run_dir.output}"
      bash "$RUN_DIR/assert.sh" > "$RUN_DIR/assert.log" 2>&1
      ASSERT_RC=$?
      printf "assert_rc=%d\n" "$ASSERT_RC"
      cat "$RUN_DIR/assert.log"
      exit $ASSERT_RC
    evaluate:
      type: exit_code
    on_yes: done
    on_no: score

  score:
    action_type: prompt
    action: |
      Goal: ${context.goal}
      Read ${captured.run_dir.output}/execute.log and ${captured.run_dir.output}/assert.log
      to diagnose. Write ${captured.run_dir.output}/critique.md:

      ```
      # Score
      goal: ${context.goal}

      ## Issues to Address
      [Specific failures from execute or assert. Be concrete about what plan.sh or
       assert.sh needs to change.]
      ```

      Output exactly: ITERATE
      (Assert is the GOAL_MET gate; this state only runs on failure.)
    evaluate:
      type: output_contains
      pattern: "ITERATE"
    on_yes: plan
    on_no: failed
    on_error: failed

  done:
    action_type: prompt
    action: |
      {{target_name}}-task completed. Assert passed.
      Output: ${captured.run_dir.output}/
      Plan: plan.sh
      Assert: assert.sh
    terminal: true

  failed:
    terminal: true
