{
  "$schema": "https://raw.githubusercontent.com/BrennonTWilliams/little-loops/main/config-schema.json",
  "install_source": "local-editable",
  "project": {
    "name": "little-loops",
    "src_dir": "scripts/",
    "test_cmd": "python -m pytest scripts/tests/",
    "lint_cmd": "ruff check scripts/",
    "format_cmd": "ruff format scripts/",
    "type_cmd": "python -m mypy scripts/little_loops/"
  },
  "issues": {
    "base_dir": ".issues"
  },
  "scan": {
    "focus_dirs": ["scripts/"],
    "exclude_patterns": [
      "**/__pycache__/**",
      "**/.venv/**",
      "**/venv/**",
      "**/dist/**",
      "**/build/**",
      "**/*.egg-info/**"
    ]
  },
  "context_monitor": {
    "enabled": true,
    "auto_handoff_threshold": 50
  },
  "scratch_pad": {
    "enabled": true,
    "threshold_lines": 200,
    "automation_contexts_only": true,
    "tail_lines": 20,
    "command_allowlist": [
      "cat",
      "pytest",
      "mypy",
      "ruff",
      "ls",
      "grep",
      "find"
    ],
    "file_extension_filters": [
      ".log",
      ".txt",
      ".json",
      ".md",
      ".py",
      ".ts",
      ".tsx",
      ".js"
    ]
  },
  "commands": {
    "confidence_gate": {
      "enabled": true,
      "readiness_threshold": 85
    },
    "tdd_mode": true
  },
  "sprints": {
    "default_max_workers": 2
  },
  "parallel": {
    "epic_branches": {
      "enabled": true,
      "prefix": "epic/",
      "merge_to_base_on_complete": true,
      "open_pr": false,
      "verify_before_merge": true
    }
  },
  "design_tokens": {
    "active": "warm-paper",
    "active_theme": "dark"
  },
  "analytics": {
    "enabled": true,
    "capture": {
      "skills": ["*"],
      "cli_commands": ["*"],
      "corrections": true,
      "file_events": true
    }
  },
  "documents": {
    "enabled": true,
    "categories": {
      "architecture": {
        "description": "System design and technical decisions",
        "files": ["docs/ARCHITECTURE.md", "docs/reference/API.md"]
      },
      "guidelines": {
        "description": "Development guidelines and conventions",
        "files": [".claude/CLAUDE.md", "CONTRIBUTING.md"]
      }
    }
  },
  "loops": {
    "run_defaults": {
      "clear": true,
      "show_diagrams": "clean"
    }
  },
  "learning_tests": {
    "enabled": true
  },
  "prompt_optimization": {
    "enabled": false
  },
  "history": {
    "session_digest": {
      "enabled": true,
      "days": 7,
      "char_cap": 1200
    },
    "compaction": {
      "enabled": true,
      "budget_tokens": 4096,
      "cross_session_enabled": true
    }
  }
}
